# API (build-time)
# VITE_API_URL=https://api.riseup.kids/api

# Schools page — WhatsApp CTA (digits with country code, e.g. 5511987654321)
VITE_SCHOOLS_WHATSAPP_NUMBER=

# Parent sales page release mode: prelaunch (waitlist, PT+ES only) | launch (full page + EN)
# VITE_SALES_PAGE_MODE=prelaunch
# VITE_SALES_PAGE_MODE=launch

# Prelaunch waitlist — checkout CTAs open Flodesk in a new tab (defaults built into app)
# Global override (all languages until per-lang URLs are set):
# VITE_PRELAUNCH_WAITLIST_URL=https://riseupkids.myflodesk.com/riseupkidsform?...
# Per language (when client provides separate forms):
# VITE_PRELAUNCH_WAITLIST_URL_PT=https://riseupkids.myflodesk.com/riseupkidsform?...
# VITE_PRELAUNCH_WAITLIST_URL_ES=https://riseupkids.myflodesk.com/...
# VITE_PRELAUNCH_WAITLIST_URL_EN=https://riseupkids.myflodesk.com/...
