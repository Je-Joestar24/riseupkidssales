# API (build-time)
# VITE_API_URL=https://api.riseup.kids/api

# Schools page — WhatsApp CTA (digits with country code, e.g. 5511987654321)
VITE_SCHOOLS_WHATSAPP_NUMBER=

# Parent sales page release mode: prelaunch (CTAs scroll to invitation) | launch (checkout)
# VITE_SALES_PAGE_MODE=prelaunch
# VITE_SALES_PAGE_MODE=launch

# Optional Flodesk URLs (for future use if CTAs link out again)
# VITE_PRELAUNCH_WAITLIST_URL=https://riseupkids.myflodesk.com/riseupkidsform?...
# VITE_PRELAUNCH_WAITLIST_URL_PT=...
# VITE_PRELAUNCH_WAITLIST_URL_ES=...
# VITE_PRELAUNCH_WAITLIST_URL_EN=...
