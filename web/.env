# API Configuration
# For local dev: leave VITE_API_URL commented so the app uses relative /api and Vite proxy (backend must run on port 5000).
# For remote API (e.g. deployed backend): set VITE_API_URL to the full API base URL.
#VITE_API_URL=http://54.226.207.14:5000/api
# Local backend (Stripe/PayPal only — PagBank needs public HTTPS URLs on server).
#VITE_API_URL=http://localhost:5000/api
# Staging API (sandbox PagBank). Use this for PagSeguro checkout tests.
VITE_API_URL=https://dp6jg4onafzr1.cloudfront.net/api
# Production API — use when riseup.kids checkout must match production PagBank payments.
# VITE_API_URL=https://api.riseup.kids/api

# Vite dev server port (optional; default 3000). Proxy uses VITE_API_URL above.
#VITE_DEV_SERVER_PORT=3000

# App Configuration
VITE_APP_NAME=Rise Up Kids
VITE_APP_VERSION=1.0.0

# PagBank redirects must be public HTTPS — use riseup.kids when API is remote/staging.
VITE_APP_URL=https://riseup.kids
#VITE_APP_URL=http://localhost:4175
# Frontend needs VITE_ prefix to read env in the browser (e.g. for success page LMS link)
VITE_LMS_URL=http://localhost:3000
#VITE_LMS_URL=https://d233tsjzju911.cloudfront.net/
#VITE_LMS_URL=https://app.riseup.kids/api

